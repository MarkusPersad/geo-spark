{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "geo-spark",
  "version": "0.1.0",
  "identifier": "org.markus-persad.geo-spark.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "geo-spark",
        "width": 1000,
        "height": 750,
        "visible": false,
        "center": true
      },
      {
        "label": "splashscreen",
        "url": "/splashscreen.html",
        "width": 400,
        "height": 300,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
